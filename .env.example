APP_NAME="Âncora"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=https://ancora.serratech.tec.br
CLIENT_PORTAL_DOMAIN=cliente.serratech.tec.br

APP_LOCALE=pt_BR
APP_FALLBACK_LOCALE=pt_BR
APP_FAKER_LOCALE=pt_BR
APP_TIMEZONE=America/Sao_Paulo

AUTOMATION_INTERNAL_TOKEN=
AUTOMATION_INTERNAL_TOKEN_HEADER=X-Integration-Token
AUTOMATION_INTERNAL_ALLOWED_IPS=
AUTOMATION_SESSION_TIMEOUT_MINUTES=30
AUTOMATION_COLLECTION_SEARCH_LIMIT=10
AUTOMATION_COLLECTION_CHALLENGE_OPTION_COUNT=5
AUTOMATION_COLLECTION_MAX_ATTEMPTS=3
AUTOMATION_COLLECTION_INSTALLMENTS_MIN=2
AUTOMATION_COLLECTION_INSTALLMENTS_MAX=12
AUTOMATION_COLLECTION_FIRST_DUE_MAX_DAYS=15
AUTOMATION_COLLECTION_MONTH_END_CUTOFF_DAYS=2
AUTOMATION_COLLECTION_INTEREST_TYPE=legal
AUTOMATION_COLLECTION_FINE_PERCENT=2
AUTOMATION_COLLECTION_ATTORNEY_FEE_EXTRAJUDICIAL=10
AUTOMATION_COLLECTION_ATTORNEY_FEE_JUDICIAL=20
AUTOMATION_COLLECTION_BOLETO_FEES_ENABLED=true
AUTOMATION_COLLECTION_BOLETO_CANCELLATION_FEES_ENABLED=true
AUTOMATION_DEMAND_DEFAULT_STATUS=aguardando_formalizacao_acordo
AUTOMATION_DEMAND_SLA_BUSINESS_HOURS=24

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=ancora
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
# Leave empty/host-only to avoid sharing the internal session with the client portal subdomain.
SESSION_DOMAIN=

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync

CACHE_STORE=file
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@serratech.tec.br"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

